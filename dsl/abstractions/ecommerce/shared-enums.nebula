SharedEnums {

    enum OrderStatus {
        PENDING,
        PAID,
        SHIPPED,
        DELIVERED,
        CANCELLED
    }

    enum PaymentStatus {
        PENDING,
        AUTHORIZED,
        FAILED,
        REFUNDED
    }

    enum ShippingStatus {
        PENDING,
        DISPATCHED,
        DELIVERED,
        FAILED
    }

    enum InvoiceStatus {
        ISSUED,
        VOIDED
    }
}
