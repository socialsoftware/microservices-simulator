Aggregate Enrollment {
    @GenerateCrud

    Entity EnrollmentCourse from Course {
        map title as courseTitle
        map description as courseDescription
        map maxStudents as courseMaxStudents
    }

    Entity EnrollmentTeacher from Teacher {
    }

    Root Entity Enrollment {
        EnrollmentCourse course
        Set<EnrollmentTeacher> teachers
        LocalDateTime enrollmentDate
        Boolean active = true

        invariants {
            check courseNotNull { course != null } error "Enrollment must have a course"
        }
    }

    References {
        course -> Course {
            onDelete: cascade
            message: "Course deleted, removing enrollments"
        }
    }

    Events {
        interInvariant COURSE_EXISTS {
            subscribe CourseDeletedEvent from Course {
                course.courseAggregateId == event.aggregateId
            }
        }
    }
}
