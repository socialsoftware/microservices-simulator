// Example 01 - Step 1.3: Add a Collection
// Customer now has multiple loyalty cards (one-to-many relationship)

Aggregate Customer {
    Root Entity Customer {
        String name;
        String email;
        Address address;
        Set<LoyaltyCard> loyaltyCards;
    }

    Entity Address {
        String street;
        String city;
        String zipCode;
    }

    Entity LoyaltyCard {
        String cardNumber;
        Integer points;
        LocalDateTime expiresAt;
    }
}
